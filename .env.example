# Copy to .env and fill real values. Never commit .env.
# chmod 600 .env after editing.

# --- Trading mode (paper | live) — default paper ---
# DO NOT set live without M6 SPEC and live_unlocked=true in DB
TRADING_MODE=paper

# --- KIS Live (실전) ---
KIS_LIVE_APP_KEY=replace-me
KIS_LIVE_APP_SECRET=replace-me
KIS_LIVE_ACCOUNT=12345678-01

# --- KIS Paper (모의) ---
KIS_PAPER_APP_KEY=replace-me
KIS_PAPER_APP_SECRET=replace-me
KIS_PAPER_ACCOUNT=50123456-01

# --- Telegram ---
TELEGRAM_BOT_TOKEN_TRADING=replace-me
TELEGRAM_CHAT_ID=60443392

# --- External market data (M3) ---
# FRED https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=replace-me
# ECOS https://ecos.bok.or.kr/api/
ECOS_API_KEY=replace-me
# OpenDART https://opendart.fss.or.kr/ (optional, may be disabled)
DART_API_KEY=replace-me-or-tbd

# --- Anthropic (M4) ---
# Generate ONCE with prepaid credits: https://console.anthropic.com
ANTHROPIC_API_KEY=replace-me

# --- KRX 계정 (pykrx 1.2.x 이후 필수, 펀더멘탈/투자자별 매매 데이터용) ---
# https://data.krx.co.kr 회원가입 후 ID/PW 입력
KRX_ID=replace-me
KRX_PW=replace-me

# --- Postgres (auto-generated by setup, see backup) ---
POSTGRES_USER=trading
POSTGRES_PASSWORD=replace-me-with-openssl-rand-hex-24
POSTGRES_DB=trading
